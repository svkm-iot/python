# Input sentence
sentence = input("Enter a sentence: ")

# Split sentence into words
words = sentence.split()

# Count occurrences
word_count = {}

for word in words:
    if word in word_count:
        word_count[word] += 1
    else:
        word_count[word] = 1

# Display result
print("Word Occurrences:")
for word, count in word_count.items():
    print(word, ":", count)
